<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Spending History - Digital Marketing CRM</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <div class="dashboard">
      <!-- Sidebar -->
      <div class="sidebar">
        <h2>Client Portal</h2>
        <nav>
          <a href="/client/dashboard">Dashboard</a>
          <a href="/client/spending" class="active">Spending History</a>
          <a href="/client/profile">My Profile</a>
        </nav>
        <div class="user-info">
          <p><strong><%= user.name %></strong></p>
          <p>Role: Client</p>
          <a href="/logout" class="btn btn-secondary btn-sm mt-2">Logout</a>
        </div>
      </div>

      <!-- Main Content -->
      <div class="main-content">
        <div class="header">
          <h1>Facebook Marketing Spending History</h1>
        </div>

        <!-- Stats -->
        <div class="stats-grid mb-3">
          <div class="stat-card">
            <h3>Total Spend</h3>
            <div class="value">$<%= spendStats.total_spend.toFixed(2) %></div>
          </div>
          <div class="stat-card">
            <h3>Total Sales Generated</h3>
            <div class="value"><%= spendStats.total_sales %></div>
          </div>
          <div class="stat-card">
            <h3>Average Cost per Sale</h3>
            <div class="value">
              <% if (spendStats.total_sales > 0) { %>
                $<%= (spendStats.total_spend / spendStats.total_sales).toFixed(2) %>
              <% } else { %>
                N/A
              <% } %>
            </div>
          </div>
        </div>

        <!-- Daily Spending Table -->
        <div class="table-container">
          <div class="table-header">
            <h2>Daily Spending Details</h2>
          </div>
          <% if (dailySpends.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Amount Spent</th>
                <th>Sales Count</th>
                <th>Cost per Sale</th>
                <th>Notes</th>
              </tr>
            </thead>
            <tbody>
              <% dailySpends.forEach(spend => { %>
              <tr>
                <td><%= new Date(spend.spend_date).toLocaleDateString() %></td>
                <td style="color: #ef4444; font-weight: 600;">$<%= spend.amount.toFixed(2) %></td>
                <td style="color: #10b981; font-weight: 600;"><%= spend.sales_count %></td>
                <td>
                  <% if (spend.sales_count > 0) { %>
                    $<%= (spend.amount / spend.sales_count).toFixed(2) %>
                  <% } else { %>
                    <span style="color: #6b7280;">N/A</span>
                  <% } %>
                </td>
                <td><%= spend.notes || '-' %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
          <% } else { %>
          <div style="padding: 40px; text-align: center; color: #6b7280;">
            <p style="font-size: 16px; margin-bottom: 10px;">No spending data available yet.</p>
            <p>Your daily Facebook Marketing spends will appear here once the admin submits them.</p>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
