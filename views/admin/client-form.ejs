<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= client ? 'Edit' : 'Add' %> Client - Digital Marketing CRM</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <div class="dashboard">
      <!-- Sidebar -->
      <div class="sidebar">
        <h2>Digital CRM</h2>
        <nav>
          <a href="/admin/dashboard">Dashboard</a>
          <a href="/admin/clients" class="active">Clients</a>
          <a href="/admin/projects">Running Projects</a>
          <a href="/admin/topups">Topup Requests</a>
        </nav>
        <div class="user-info">
          <p><strong><%= user.name %></strong></p>
          <p>Role: <%= user.role %></p>
          <a href="/logout" class="btn btn-secondary btn-sm mt-2">Logout</a>
        </div>
      </div>

      <!-- Main Content -->
      <div class="main-content">
        <div class="header">
          <h1><%= client ? 'Edit' : 'Add New' %> Client</h1>
          <a href="/admin/clients" class="btn btn-secondary">Back to Clients</a>
        </div>

        <div class="table-container">
          <div style="padding: 30px;">
            <% if (error) { %>
              <div class="error-message"><%= error %></div>
            <% } %>
            
            <form method="POST" action="/admin/clients/add">
              <div class="grid-2">
                <div class="form-group">
                  <label for="name">Full Name *</label>
                  <input type="text" id="name" name="name" required>
                </div>
                <div class="form-group">
                  <label for="username">Username *</label>
                  <input type="text" id="username" name="username" required>
                </div>
                <div class="form-group">
                  <label for="email">Email</label>
                  <input type="email" id="email" name="email">
                </div>
                <div class="form-group">
                  <label for="phone">Phone</label>
                  <input type="text" id="phone" name="phone">
                </div>
                <div class="form-group">
                  <label for="facebook_link">Facebook Profile Link</label>
                  <input type="url" id="facebook_link" name="facebook_link">
                </div>
                <div class="form-group">
                  <label for="whatsapp_number">WhatsApp Number</label>
                  <input type="text" id="whatsapp_number" name="whatsapp_number" placeholder="+8801XXXXXXXXX">
                </div>
                <div class="form-group">
                  <label for="initial_balance">Initial Balance ($)</label>
                  <input type="number" id="initial_balance" name="initial_balance" step="0.01" min="0" value="0">
                </div>
              </div>
              
              <div class="mt-3">
                <button type="submit" class="btn btn-primary">Add Client</button>
                <a href="/admin/clients" class="btn btn-secondary">Cancel</a>
              </div>
              
              <p class="mt-2" style="color: #6b7280; font-size: 14px;">
                * Default password will be: <strong>client123</strong>
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
