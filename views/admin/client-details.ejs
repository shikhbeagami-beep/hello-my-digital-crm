<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Client Details - Digital Marketing CRM</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <div class="dashboard">
      <!-- Sidebar -->
      <div class="sidebar">
        <h2>Digital CRM</h2>
        <nav>
          <a href="/admin/dashboard">Dashboard</a>
          <a href="/admin/clients" class="active">Clients</a>
          <a href="/admin/projects">Running Projects</a>
          <a href="/admin/topups">Topup Requests</a>
        </nav>
        <div class="user-info">
          <p><strong><%= user.name %></strong></p>
          <p>Role: <%= user.role %></p>
          <a href="/logout" class="btn btn-secondary btn-sm mt-2">Logout</a>
        </div>
      </div>

      <!-- Main Content -->
      <div class="main-content">
        <div class="header">
          <h1><%= client.name %> - Details</h1>
          <a href="/admin/clients" class="btn btn-secondary">Back to Clients</a>
        </div>

        <!-- Client Info -->
        <div class="stats-grid">
          <div class="stat-card">
            <h3>Current Balance</h3>
            <div class="value">$<%= client.balance.toFixed(2) %></div>
          </div>
          <div class="stat-card">
            <h3>Total Spend</h3>
            <div class="value">$<%= spendStats.total_spend.toFixed(2) %></div>
          </div>
          <div class="stat-card">
            <h3>Total Sales</h3>
            <div class="value"><%= spendStats.total_sales %></div>
          </div>
        </div>

        <!-- Client Details -->
        <div class="table-container mb-3">
          <div class="table-header">
            <h2>Client Information</h2>
          </div>
          <div style="padding: 20px;">
            <div class="grid-2">
              <div>
                <p><strong>Name:</strong> <%= client.name %></p>
                <p><strong>Email:</strong> <%= client.email || 'N/A' %></p>
                <p><strong>Phone:</strong> <%= client.phone || 'N/A' %></p>
              </div>
              <div>
                <p><strong>Facebook:</strong> <%= client.facebook_link ? `<a href="${client.facebook_link}" target="_blank">View Profile</a>` : 'N/A' %></p>
                <p><strong>WhatsApp:</strong> <%= client.whatsapp_number || 'N/A' %></p>
                <p><strong>Username:</strong> <%= client.username %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Submit Daily Spend -->
        <div class="table-container mb-3">
          <div class="table-header">
            <h2>Submit Daily Spend</h2>
          </div>
          <div style="padding: 20px;">
            <form method="POST" action="/admin/clients/<%= client.id %>/daily-spend">
              <div class="grid-2">
                <div class="form-group">
                  <label for="spend_date">Date</label>
                  <input type="date" id="spend_date" name="spend_date" required value="<%= new Date().toISOString().split('T')[0] %>">
                </div>
                <div class="form-group">
                  <label for="amount">Amount ($)</label>
                  <input type="number" id="amount" name="amount" step="0.01" min="0" required>
                </div>
                <div class="form-group">
                  <label for="sales_count">Sales Count</label>
                  <input type="number" id="sales_count" name="sales_count" min="0" value="0">
                </div>
                <div class="form-group">
                  <label for="notes">Notes</label>
                  <input type="text" id="notes" name="notes">
                </div>
              </div>
              <button type="submit" class="btn btn-primary mt-2">Submit Spend</button>
            </form>
          </div>
        </div>

        <!-- Daily Spending History -->
        <div class="table-container mb-3">
          <div class="table-header">
            <h2>Daily Spending History</h2>
          </div>
          <% if (dailySpends.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Amount</th>
                <th>Sales Count</th>
                <th>Cost per Sale</th>
                <th>Notes</th>
              </tr>
            </thead>
            <tbody>
              <% dailySpends.forEach(spend => { %>
              <tr>
                <td><%= new Date(spend.spend_date).toLocaleDateString() %></td>
                <td>$<%= spend.amount.toFixed(2) %></td>
                <td><%= spend.sales_count %></td>
                <td>
                  <% if (spend.sales_count > 0) { %>
                    $<%= (spend.amount / spend.sales_count).toFixed(2) %>
                  <% } else { %>
                    N/A
                  <% } %>
                </td>
                <td><%= spend.notes || '-' %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
          <% } else { %>
          <div style="padding: 20px; text-align: center; color: #6b7280;">
            No spending history yet.
          </div>
          <% } %>
        </div>

        <!-- Projects -->
        <div class="table-container mb-3">
          <div class="table-header">
            <h2>Projects</h2>
          </div>
          <% if (projects.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Project Name</th>
                <th>Type</th>
                <th>Status</th>
                <th>Assigned To</th>
              </tr>
            </thead>
            <tbody>
              <% projects.forEach(project => { %>
              <tr>
                <td><%= project.project_name %></td>
                <td><span class="badge badge-info"><%= project.project_type.replace('_', ' ') %></span></td>
                <td><span class="badge badge-warning"><%= project.status %></span></td>
                <td><%= project.assigned_to_name || 'Unassigned' %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
          <% } else { %>
          <div style="padding: 20px; text-align: center; color: #6b7280;">
            No projects yet.
          </div>
          <% } %>
        </div>

        <!-- Topup Requests -->
        <div class="table-container">
          <div class="table-header">
            <h2>Topup Requests</h2>
          </div>
          <% if (topupRequests.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Amount</th>
                <th>Status</th>
                <th>Requested</th>
                <th>Processed</th>
              </tr>
            </thead>
            <tbody>
              <% topupRequests.forEach(topup => { %>
              <tr>
                <td>$<%= topup.amount.toFixed(2) %></td>
                <td>
                  <span class="badge badge-<%= topup.status === 'approved' ? 'success' : topup.status === 'rejected' ? 'danger' : 'warning' %>">
                    <%= topup.status %>
                  </span>
                </td>
                <td><%= new Date(topup.requested_at).toLocaleDateString() %></td>
                <td><%= topup.processed_at ? new Date(topup.processed_at).toLocaleDateString() : '-' %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
          <% } else { %>
          <div style="padding: 20px; text-align: center; color: #6b7280;">
            No topup requests yet.
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
